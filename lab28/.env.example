# Lab 28 — Full AI Infrastructure Platform
# Copy to .env and fill in your values

# FPT Cloud AI Marketplace
FPT_API_KEY=sk-your-api-key-here
FPT_LLM_ENDPOINT=https://mkp-api.fptcloud.com/chat/completions
FPT_EMBED_ENDPOINT=https://mkp-api.fptcloud.com/embeddings
FPT_LLM_MODEL=Qwen2.5-7B-Instruct
FPT_EMBED_MODEL=Vietnamese_Embedding

# LangSmith (LangChain tracing) — optional
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=lab28-platform

# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# Governance — Encryption key (32 hex chars = 16 bytes)
GOVERNANCE_ENCRYPTION_KEY=00000000000000000000000000000000
